# HabitForge Environment Variables Template
# Copy this file to .env and update with your actual values

# Application
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# MongoDB Configuration
MONGODB_URI=mongodb://habitforge:***REMOVED***@localhost:27017/habitforge?authSource=admin
MONGO_INITDB_ROOT_USERNAME=habitforge
MONGO_INITDB_ROOT_PASSWORD=***REMOVED***
MONGO_INITDB_DATABASE=habitforge

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=***REMOVED***

# Service URLs (for inter-service communication)
USER_SERVICE_URL=http://localhost:3001
HABIT_SERVICE_URL=http://localhost:3002
CLUB_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004

# API Gateway
API_GATEWAY_PORT=3000

# Rate Limiting (requests per hour)
RATE_LIMIT_DISCIPLINE=100
RATE_LIMIT_BALANCED=150
RATE_LIMIT_COMPETITIVE=300

# Gamification Settings
BASE_XP=10
MAX_STREAK_BONUS=2.0
DISCIPLINE_MODE_MULTIPLIER=1.5
BALANCED_MODE_MULTIPLIER=1.0
COMPETITIVE_MODE_MULTIPLIER=1.2
