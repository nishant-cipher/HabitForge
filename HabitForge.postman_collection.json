    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string",
            "description": "API Gateway URL (Docker Desktop)"
        },
        {
            "key": "accessToken",
            "value": "",
            "type": "string",
            "description": "JWT access token (auto-populated on login/register)"
        },
        {
            "key": "refreshToken",
            "value": "",
            "type": "string",
            "description": "JWT refresh token (auto-populated on login/register)"
        },
        {
            "key": "habitId",
            "value": "",
            "type": "string",
            "description": "Habit ID (auto-populated on create habit)"
        },
        {
            "key": "clubId",
            "value": "",
            "type": "string",
            "description": "Club ID (auto-populated on create club)"
        },
        {
            "key": "clubHabitId",
            "value": "",
            "type": "string",
            "description": "Club Habit/Task ID (auto-populated on add club task)"
        }
    ],
