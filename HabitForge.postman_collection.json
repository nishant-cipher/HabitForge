        {
            "name": "🔐 Authentication",
            "item": [
                {
                    "name": "Register User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    const response = pm.response.json();",
                                    "    const data = response.data;",
                                    "    pm.collectionVariables.set('accessToken', data.accessToken);",
                                    "    pm.collectionVariables.set('refreshToken', data.refreshToken);",
                                    "    console.log('✅ Registered! Access token saved.');",
                                    "    pm.test('Registration successful', () => pm.response.to.have.status(201));",
                                    "    pm.test('Has accessToken', () => pm.expect(data.accessToken).to.be.a('string'));",
                                    "    pm.test('Has user object', () => pm.expect(data.user).to.be.an('object'));",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"username\": \"testuser\",\n  \"password\": \"password123\",\n  \"mode\": \"BALANCED\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
